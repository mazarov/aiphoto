# === Required ===
TELEGRAM_BOT_TOKEN=
SUPABASE_SUPABASE_PUBLIC_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=your-gemini-api-key
# Proxy for Gemini API (geo-block bypass). If not set, calls Google directly.
# GEMINI_PROXY_BASE_URL=https://gemini-proxy.photo2sticker.ru
# Verbose Gemini request/response text previews for /api/vibe/extract and /api/vibe/expand (server logs).
# GEMINI_VIBE_DEBUG=1
# Log full assembled text prompt in /api/generate-process (default on). Set 0 to reduce log volume.
# LANDING_LOG_FULL_GENERATION_PROMPT=1
# Vibe image-gen: fallback only if photo_app_config.vibe_attach_reference_image_to_generation is missing/unreadable.
# VIBE_ATTACH_REFERENCE_IMAGE_TO_GENERATION=0
# Vibe LLM models: fallback if photo_app_config rows missing (defaults: extract=gemini-2.5-pro, expand=gemini-2.5-flash)
# GEMINI_VIBE_EXTRACT_MODEL=gemini-2.5-pro
# GEMINI_VIBE_EXPAND_MODEL=gemini-2.5-flash
# One-shot vibe extract (fallback; primary toggle: photo_app_config.vibe_one_shot_extract_prompt)
# VIBE_ONE_SHOT_EXTRACT_PROMPT=false
# Vibe extract/expand LLM: gemini | openai (landing; requires OPENAI_API_KEY when openai)
# VIBE_EXTRACT_LLM=gemini
# VIBE_EXPAND_LLM=gemini
# VIBE_OPENAI_EXTRACT_MODEL=gpt-4o
# VIBE_OPENAI_EXPAND_MODEL=gpt-4.1-mini
# OpenAI API (used by SEO pipeline scripts: fill-seo-tags, translate, fix-titles)
OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1  # optional, for custom endpoints
# LLM_MODEL=gpt-4.1-mini                      # optional, default model for pipeline

# Landing Auth (Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
TELEGRAM_BOT_LINK=https://t.me/your_payment_bot

# === Optional ===
APP_ENV=prod
# APP_ENV=test  # for test bot

SUPABASE_STORAGE_BUCKET=photos
PORT=3001
WEBHOOK_PATH=/telegram/webhook
PUBLIC_BASE_URL=https://your-domain.dockhost.ru
BOT_USERNAME=your_bot_username

# AI Chat (assistant feature)
AI_CHAT_PROVIDER=gemini
# AI_CHAT_MODEL=  # empty = use default per provider
# OPENAI_API_KEY=  # only if AI_CHAT_PROVIDER=openai

# Alerts & Support
ALERT_CHANNEL_ID=
SUPPORT_BOT_TOKEN=
SUPPORT_CHANNEL_ID=
SUPPORT_BOT_USERNAME=

# Admin
ADMIN_IDS=123456789

# Webhook secret (optional, for security)
TELEGRAM_WEBHOOK_SECRET=

# Job polling interval (ms)
JOB_POLL_INTERVAL_MS=2000
