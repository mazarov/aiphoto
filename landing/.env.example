# Supabase (скопировать из photo2sticker-bot/.env)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.dockhost.net
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Публичные URL медиа карточек через Storage Image Transformation (imgproxy + ENABLE_IMAGE_TRANSFORMATION на storage-api). Без этого — обычный /object/public/
# NEXT_PUBLIC_SUPABASE_STORAGE_IMAGE_TRANSFORM=1

# Gemini
GEMINI_API_KEY=xxx
GEMINI_PROXY_BASE_URL=https://your-proxy.example.com
# Optional vibe model overrides if photo_app_config row missing (defaults: extract=gemini-2.5-pro, expand=gemini-2.5-flash)
# GEMINI_VIBE_EXTRACT_MODEL=gemini-2.5-pro
# GEMINI_VIBE_EXPAND_MODEL=gemini-2.5-flash
# One-shot extract: single vision call → { "prompt" }; expand uses vibes.prefilled_generation_prompt (default off; DB photo_app_config.vibe_one_shot_extract_prompt overrides)
# VIBE_ONE_SHOT_EXTRACT_PROMPT=false

# Optional: OpenAI for vibe extract/expand (photo_app_config vibe_extract_llm / vibe_expand_llm = openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# VIBE_EXTRACT_LLM=gemini
# VIBE_EXPAND_LLM=openai
# VIBE_OPENAI_EXTRACT_MODEL=gpt-4o
# VIBE_OPENAI_EXPAND_MODEL=gpt-4.1-mini

# Runtime origin for server-side internal callbacks
NEXT_PUBLIC_SITE_URL=https://promptshot.ru
# Marketing page /extension-stv — primary CTA (optional; default #stv-chrome-store)
# NEXT_PUBLIC_STV_CHROME_STORE_URL=https://chromewebstore.google.com/detail/...
# Full URL or bare @username / bot username (API normalizes to https://t.me/...)
TELEGRAM_BOT_LINK=https://t.me/your_payment_bot

# CORS allowlist for chrome extension
# Preferred: set extension id explicitly
CHROME_EXTENSION_ID=abcdefghijklmnopabcdefghijklmnop
# Or use explicit CSV list:
# CORS_ALLOWED_ORIGINS=chrome-extension://abcdefghijklmnopabcdefghijklmnop

# Public "Try this look" CTA on prompt cards
# NEXT_PUBLIC_ENABLE_TRY_THIS_LOOK=true
