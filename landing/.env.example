# Supabase (скопировать из photo2sticker-bot/.env)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.dockhost.net
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Gemini
GEMINI_API_KEY=xxx
GEMINI_PROXY_BASE_URL=https://your-proxy.example.com
# Optional model overrides for vibe pipeline
# GEMINI_VIBE_EXTRACT_MODEL=gemini-2.5-flash
# GEMINI_VIBE_EXPAND_MODEL=gemini-2.5-flash

# Runtime origin for server-side internal callbacks
NEXT_PUBLIC_SITE_URL=https://promptshot.ru

# CORS allowlist for chrome extension
# Preferred: set extension id explicitly
CHROME_EXTENSION_ID=abcdefghijklmnopabcdefghijklmnop
# Or use explicit CSV list:
# CORS_ALLOWED_ORIGINS=chrome-extension://abcdefghijklmnopabcdefghijklmnop

# Public "Try this look" CTA on prompt cards
# NEXT_PUBLIC_ENABLE_TRY_THIS_LOOK=true
