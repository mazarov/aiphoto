{
  "name": "aiphoto-bot-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "cd payment-bot && npm run dev",
    "dev:test:api": "cd payment-bot && DOTENV_CONFIG_PATH=.env.test npx tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:api": "cd payment-bot && npm run build",
    "start:api": "cd payment-bot && npm run start",
    "check:entrypoints": "node scripts/check-entrypoints.mjs",
    "parse:telegram:xlsx": "tsx src/parse-telegram-export-to-xlsx.ts",
    "ingest:telegram:supabase": "tsx src/ingest-telegram-export-to-supabase.ts",
    "build:prompt-cards:prototype": "tsx src/build-local-prompt-cards-prototype.ts",
    "fill:hashtags": "tsx src/fill-hashtags-from-prompts.ts",
    "fill:seo-tags": "tsx src/fill-seo-tags.ts",
    "fix:prompt-marker-titles": "tsx src/fix-prompt-marker-titles.ts",
    "retitle:all": "tsx src/fix-prompt-marker-titles.ts",
    "fill:seo-tags:root-env": "cd .. && node -r dotenv/config ./node_modules/.bin/tsx aiphoto/src/fill-seo-tags.ts",
    "backfill:media-dimensions": "tsx src/backfill-prompt-card-media-dimensions.ts",
    "backfill:media-dimensions:dry": "tsx src/backfill-prompt-card-media-dimensions.ts --dry-run",
    "backfill:ugc-from-generations": "cd landing && npx tsx scripts/backfill-ugc-from-generations.ts",
    "backfill:ugc-from-generations:dry": "cd landing && npx tsx scripts/backfill-ugc-from-generations.ts --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.0",
    "axios": "^1.7.9",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "image-size": "^1.2.1",
    "telegraf": "^4.16.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.0",
    "tsx": "^4.20.5",
    "typescript": "5.6.3"
  }
}
